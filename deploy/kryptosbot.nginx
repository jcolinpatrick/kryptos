server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name kryptosbot.com www.kryptosbot.com;

    root /home/cpatrick/kryptos/site;
    index index.html;

    # --- Security: deny access to databases and dotfiles ---
    location ~* \.sqlite$ { deny all; return 404; }
    location ^~ /db/          { deny all; return 404; }
    location ~ /\.            { deny all; return 404; }

    # --- API reverse proxy ---
    location /api/ {
        proxy_pass http://127.0.0.1:8321;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Timeouts — classification calls Claude, allow up to 30s
        proxy_read_timeout 30s;
        proxy_send_timeout 10s;
    }

    # --- Static files with clean URLs ---
    # Try exact path, then path/, then path/index.html, then 404
    location / {
        try_files $uri $uri/ $uri/index.html =404;
    }

    # Cache static assets
    location ~* \.(css|js|png|jpg|jpeg|gif|ico|svg|woff2?)$ {
        expires 7d;
        add_header Cache-Control "public, immutable";
    }

    # certbot will add the 443 block when you run:
    #   sudo certbot --nginx -d kryptosbot.com -d www.kryptosbot.com
}
